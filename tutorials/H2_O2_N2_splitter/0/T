FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 1500;

boundaryField
{
    inletAir
    {
        type            codedFixedValue;
        value           uniform 1500;
        name            tanhMixingT;
        code
        #{
            const vectorField& Cf = patch().Cf();
            scalarField& T = *this;
            const scalar y0    = 2.5e-3;
            const scalar delta = 3.333e-5;
            const scalar T_H2  = 350.0;
            const scalar T_air = 1500.0;
            forAll(T, faceI)
            {
                const scalar y = Cf[faceI].y();
                const scalar s = 0.5*(1.0 + Foam::tanh((y - y0)/delta));
                T[faceI] = (1.0 - s)*T_H2 + s*T_air;
            }
        #};
    }

    inletFuel
    {
        type            codedFixedValue;
        value           uniform 350;
        name            tanhMixingT;
        code
        #{
            const vectorField& Cf = patch().Cf();
            scalarField& T = *this;
            const scalar y0    = 2.5e-3;
            const scalar delta = 3.333e-5;
            const scalar T_H2  = 350.0;
            const scalar T_air = 1500.0;
            forAll(T, faceI)
            {
                const scalar y = Cf[faceI].y();
                const scalar s = 0.5*(1.0 + Foam::tanh((y - y0)/delta));
                T[faceI] = (1.0 - s)*T_H2 + s*T_air;
            }
        #};
    }

    top
    {
        type        zeroGradient;
    }

    bottom
    {
        type        zeroGradient;
    }

    outlet
    {
        type        zeroGradient;
    }

    frontAndBack
    {
        type        empty;
    }
}

