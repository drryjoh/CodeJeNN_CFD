FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Air:  M=0.3, c=753 m/s  =>  U = 226 m/s
// Fuel: M=0.3, c=1422 m/s =>  U = 427 m/s
// Interior initialised with air conditions.

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (226 0 0);

boundaryField
{
    inletAir
    {
        type            codedFixedValue;
        value           uniform (226 0 0);
        name            tanhMixingU;
        code
        #{
            const vectorField& Cf = patch().Cf();
            vectorField& U = *this;
            const scalar y0    = 2.5e-3;
            const scalar delta = 3.333e-5;
            const scalar U_H2  = 427.0;
            const scalar U_air = 226.0;
            forAll(U, faceI)
            {
                const scalar y = Cf[faceI].y();
                const scalar s = 0.5*(1.0 + Foam::tanh((y - y0)/delta));
                U[faceI] = vector((1.0 - s)*U_H2 + s*U_air, 0.0, 0.0);
            }
        #};
    }

    inletFuel
    {
        type            codedFixedValue;
        value           uniform (427 0 0);
        name            tanhMixingU;
        code
        #{
            const vectorField& Cf = patch().Cf();
            vectorField& U = *this;
            const scalar y0    = 2.5e-3;
            const scalar delta = 3.333e-5;
            const scalar U_H2  = 427.0;
            const scalar U_air = 226.0;
            forAll(U, faceI)
            {
                const scalar y = Cf[faceI].y();
                const scalar s = 0.5*(1.0 + Foam::tanh((y - y0)/delta));
                U[faceI] = vector((1.0 - s)*U_H2 + s*U_air, 0.0, 0.0);
            }
        #};
    }

    top
    {
        type        zeroGradient;
    }

    bottom
    {
        type        zeroGradient;
    }

    outlet
    {
        type        zeroGradient;
    }

    frontAndBack
    {
        type        empty;
    }
}

