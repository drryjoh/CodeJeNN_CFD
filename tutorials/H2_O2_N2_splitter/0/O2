FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      O2;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0.233;

boundaryField
{
    inletAir
    {
        type        fixedValue;
        value       uniform 0.233;
    }

    inletFuel
    {
        type        fixedValue;
        value       uniform 0;
    }

    top
    {
        type        zeroGradient;
    }

    bottom
    {
        type        zeroGradient;
    }

    outlet
    {
        type        zeroGradient;
    }

    frontAndBack
    {
        type        empty;
    }
}

